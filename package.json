{
  "name": "multaiplayer",
  "private": true,
  "version": "0.1.0-alpha.17",
  "description": "Private group chat for coding with Codex. Open source.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24 <25"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "edgedriver@6.3.0": false,
    "fsevents@2.3.2": false,
    "fsevents@2.3.3": false,
    "geckodriver@6.1.0": false
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm run build -w @multaiplayer/protocol",
    "build:apps": "npm run build -w @multaiplayer/relay && npm run build -w @multaiplayer/desktop",
    "check": "npm run build:packages && npm run check --workspaces --if-present",
    "lint": "eslint eslint.config.mjs \"{apps,packages,scripts,e2e,tools}/**/*.{ts,tsx,mjs}\"",
    "format": "prettier --write eslint.config.mjs \"{apps,packages,scripts,e2e,tools}/**/*.{ts,tsx,mjs,css}\"",
    "format:check": "prettier --check eslint.config.mjs \"{apps,packages,scripts,e2e,tools}/**/*.{ts,tsx,mjs,css}\"",
    "test:workspaces": "npm run test --workspaces --if-present",
    "test:release-tools": "node --test tools/release/*.test.mjs",
    "check:security-exceptions": "node tools/security/check-exception-expiry.mjs",
    "audit:npm": "npm audit --audit-level=high",
    "test": "npm run build:packages && npm run test:workspaces",
    "test:ui-contract": "node scripts/run-ui-contract.mjs",
    "docs:screenshots": "node e2e/capture-readme-screens.mjs",
    "test:e2e:native": "node --import tsx e2e/native-shell/journey.ts",
    "test:e2e:native:macos-smoke": "wdio run e2e/native-macos/wdio.conf.mjs",
    "docs:check": "node scripts/check-maintained-docs.mjs && node scripts/check-repository-content.mjs",
    "fmt:rust:check": "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --all -- --check",
    "lint:rust": "cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml --workspace --all-targets --all-features -- -D warnings",
    "test:native": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml --workspace --all-features",
    "hooks:install": "git config core.hooksPath .githooks",
    "verify": "npm run lint && npm run format:check && npm run docs:check && npm run check:security-exceptions && npm run test:release-tools && npm run build:packages && npm run test:workspaces && npm run build:apps && npm run check:release-versions && npm run fmt:rust:check && npm run lint:rust && npm run test:native",
    "verify:aasa": "node scripts/verify-macos-associated-domains.mjs --live",
    "verify:macos-associated-domains": "node scripts/verify-macos-associated-domains.mjs",
    "check:release-versions": "node scripts/check-release-versions.mjs",
    "doctor": "node scripts/doctor.mjs",
    "sync:release-versions": "node tools/release/sync-release-metadata.mjs",
    "finalize:release-changelog": "node tools/release/finalize-changelog.mjs",
    "license:check": "node scripts/license-check.mjs && node scripts/cargo-license-notices-check.mjs",
    "sqlite:backup-restore-drill": "node --import tsx e2e/relay/sqlite-backup-restore-drill.mjs --fixture",
    "verify:release-assets": "node tools/release/check-release-assets.mjs",
    "verify:updater-contract": "node tools/release/verify-updater-contract.mjs",
    "dev": "concurrently -k --names relay,desktop --prefix-colors cyan,green \"npm:dev:relay\" \"npm:dev:desktop\"",
    "dev:desktop": "npm run dev -w @multaiplayer/desktop",
    "build:mls-validator:dev": "cargo build --locked --manifest-path apps/desktop/src-tauri/Cargo.toml -p mls-core --bin mls-keypackage-validator",
    "dev:relay": "npm run build:mls-validator:dev && node --env-file-if-exists=.env node_modules/.bin/tsx watch apps/relay/src/index.ts",
    "tauri:dev": "npm run tauri:dev -w @multaiplayer/desktop",
    "tauri:build": "npm run tauri:build -w @multaiplayer/desktop"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@vitejs/plugin-react": "6.0.3",
    "@wdio/cli": "9.29.1",
    "@wdio/globals": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "1.2.0",
    "concurrently": "10.0.3",
    "dompurify": "3.4.12",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "webdriverio": "9.29.1",
    "yaml": "2.9.0"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0",
    "encoding-sniffer": "1.0.2",
    "glob": "13.0.6",
    "shell-quote": "1.10.0",
    "serialize-javascript": "7.0.5",
    "monaco-editor": {
      "dompurify": "$dompurify"
    }
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.28.1",
    "@esbuild/darwin-x64": "0.28.1",
    "@esbuild/linux-arm64": "0.28.1",
    "@esbuild/linux-x64": "0.28.1",
    "@esbuild/win32-arm64": "0.28.1",
    "@esbuild/win32-x64": "0.28.1"
  }
}
