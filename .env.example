GITHUB_CLIENT_ID=
GITHUB_OAUTH_SCOPES=read:user repo
# Optional. Use at least 32 characters to persist encrypted GitHub sessions across relay restarts.
MULTAIPLAYER_RELAY_SESSION_SECRET=
# Required for hosted account deletion. The HMAC key must be separate from S3 credentials and session encryption.
# Railway Buckets currently use region=auto and virtual-host URL style. Keep the bucket outside SQLite backup sets.
MULTAIPLAYER_RELAY_DELETION_LEDGER_S3_ENDPOINT=
MULTAIPLAYER_RELAY_DELETION_LEDGER_S3_BUCKET=
MULTAIPLAYER_RELAY_DELETION_LEDGER_S3_REGION=auto
MULTAIPLAYER_RELAY_DELETION_LEDGER_S3_ACCESS_KEY_ID=
MULTAIPLAYER_RELAY_DELETION_LEDGER_S3_SECRET_ACCESS_KEY=
MULTAIPLAYER_RELAY_DELETION_LEDGER_S3_URL_STYLE=virtual-host
MULTAIPLAYER_RELAY_DELETION_LEDGER_S3_PREFIX=relay-deletions/v1
MULTAIPLAYER_RELAY_DELETION_LEDGER_HMAC_KEY=
# Must exceed the longest backup retention. Official Railway: 90 days protecting an 89-day snapshot window.
MULTAIPLAYER_RELAY_DELETION_LEDGER_PROTECTION_SECONDS=7776000
# Development/self-hosting alternative. The directory must be outside every primary-store backup set.
# MULTAIPLAYER_RELAY_DELETION_LEDGER_FILE_PATH=.multaiplayer/deletion-ledger
# Optional. Enables authenticated Prometheus scraping at /metrics; use at least 32 characters.
MULTAIPLAYER_RELAY_METRICS_TOKEN=
# SQLite is the safe default. Set storage=json explicitly only for local migration/development.
MULTAIPLAYER_RELAY_STORAGE=sqlite
MULTAIPLAYER_RELAY_DATA_PATH=.multaiplayer/relay-store.sqlite
MULTAIPLAYER_MLS_VALIDATOR_PATH=apps/desktop/src-tauri/target/debug/mls-keypackage-validator
MULTAIPLAYER_RELAY_BACKLOG_LIMIT=200
MULTAIPLAYER_RELAY_BACKLOG_RETENTION_DAYS=30
MULTAIPLAYER_RELAY_MLS_MESSAGE_MAX_BYTES=1000000
MULTAIPLAYER_RELAY_INVITE_TTL_DAYS=7
MULTAIPLAYER_ATTACHMENT_BLOB_TTL_DAYS=30
MULTAIPLAYER_ATTACHMENT_BLOB_MAX_BYTES=5000000
MULTAIPLAYER_ATTACHMENT_BLOB_LIVE_QUOTA_BYTES=250000000
MULTAIPLAYER_ATTACHMENT_BLOB_UPLOAD_BYTES_PER_WINDOW=100000000
MULTAIPLAYER_ATTACHMENT_BLOB_UPLOAD_WINDOW_MS=3600000
MULTAIPLAYER_RELAY_DEBUG=false
MULTAIPLAYER_RELAY_STRUCTURED_LOGS=false
# Local/dev default. In production, auth is required by default unless this is explicitly set to false.
# Set to false only for an intentionally open private LAN/local relay.
MULTAIPLAYER_RELAY_REQUIRE_AUTH=true
MULTAIPLAYER_RELAY_ALLOWED_ORIGINS=http://127.0.0.1:1420,http://localhost:1420
MULTAIPLAYER_RELAY_RATE_LIMITS=true
MULTAIPLAYER_RELAY_RATE_LIMIT_WINDOW_MS=60000
MULTAIPLAYER_RELAY_RATE_LIMIT_AUTH=30
MULTAIPLAYER_RELAY_RATE_LIMIT_READ=300
MULTAIPLAYER_RELAY_RATE_LIMIT_MUTATION=120
MULTAIPLAYER_RELAY_RATE_LIMIT_ATTACHMENT=60
MULTAIPLAYER_RELAY_RATE_LIMIT_WEBSOCKET=600
MULTAIPLAYER_RELAY_RATE_LIMIT_WEBSOCKET_CONNECT=120
MULTAIPLAYER_RELAY_WEBSOCKET_CONNECTION_CAP_USER=20
MULTAIPLAYER_RELAY_WEBSOCKET_CONNECTION_CAP_DEVICE=5
MULTAIPLAYER_RELAY_DAILY_TEAM_CREATION_CAP=25
MULTAIPLAYER_RELAY_DAILY_ROOM_CREATION_CAP=100
MULTAIPLAYER_RELAY_TOTAL_ROOM_CAP_USER=500
# Shutdown drain is milliseconds, defaults to 0, and accepts 0-60000 inclusive.
# Readiness flips immediately; drain allows load balancers to stop routing before sockets close.
MULTAIPLAYER_RELAY_SHUTDOWN_DRAIN_MS=0
MULTAIPLAYER_RELAY_SHUTDOWN_GRACE_MS=10000
# Keep false unless the relay is behind a trusted reverse proxy that overwrites X-Forwarded-For.
MULTAIPLAYER_RELAY_TRUST_PROXY_HEADERS=false
MULTAIPLAYER_RELAY_TRUSTED_PROXY_CONFIGURED=false
# Local/self-hosted development endpoints. Release builds must supply the configured hosted relay.
VITE_RELAY_HTTP_URL=http://127.0.0.1:4321
VITE_RELAY_URL=ws://127.0.0.1:4321/rooms
VITE_ALLOW_RELAY_CONFIGURATION=true
