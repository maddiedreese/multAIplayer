# Loopback development profile. Relay tuning has safe defaults in code; production
# and self-hosted configuration belongs in docs/self-hosting.md, not this file.
MULTAIPLAYER_RELAY_DATA_PATH=.multaiplayer/relay-store.sqlite

# Local development has no separately trusted HTTPS OAuth relay. Never expose this
# auth-disabled relay to a LAN or the internet; production pre-deploy rejects it.
MULTAIPLAYER_RELAY_UNSAFE_DISABLE_AUTH=true
MULTAIPLAYER_RELAY_ALLOWED_ORIGINS=http://127.0.0.1:1420,http://localhost:1420

VITE_RELAY_HTTP_URL=http://127.0.0.1:4321
VITE_RELAY_URL=ws://127.0.0.1:4321/rooms
VITE_ALLOW_RELAY_CONFIGURATION=true
