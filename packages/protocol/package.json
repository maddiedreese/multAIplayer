{
  "name": "@multaiplayer/protocol",
  "version": "0.1.0-alpha.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "test:coverage": "c8 --all --src src --include 'src/**/*.ts' --exclude 'src/app-types.ts' --report-dir coverage --reporter=text --reporter=json-summary --reporter=lcov --check-coverage --lines=100 --functions=100 --branches=100 --statements=100 tsx --test test/*.test.ts",
    "test:mutation:run": "stryker run",
    "test:mutation:summary": "node ../../scripts/summarize-mutation-report.mjs reports/mutation/mutation.json --output reports/mutation/summary.json",
    "test:mutation:policy": "node ../../scripts/check-mutation-policy.mjs reports/mutation/summary.json mutation-policy.json",
    "test:mutation": "npm run test:mutation:run && npm run test:mutation:summary && npm run test:mutation:policy"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "fast-check": "4.9.0",
    "tsx": "4.23.0",
    "typescript": "7.0.2"
  }
}
