{
  "name": "@multaiplayer/git",
  "version": "0.1.0-alpha.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "test:coverage": "c8 --all --src src --include 'src/**/*.ts' --report-dir coverage --reporter=text --reporter=json-summary --reporter=lcov --check-coverage --lines=95 --functions=95 --branches=90 --statements=95 tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  }
}
