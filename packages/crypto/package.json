{
  "name": "@multaiplayer/crypto",
  "version": "0.1.0-alpha.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "test:coverage": "c8 --all --src src --include 'src/**/*.ts' --report-dir coverage --reporter=text --reporter=json-summary --reporter=lcov --check-coverage --lines=90 --functions=90 --branches=80 --statements=90 tsx --test test/*.test.ts",
    "test:mutation:run": "stryker run",
    "test:mutation:summary": "node ../../scripts/summarize-mutation-report.mjs reports/mutation/mutation.json --output reports/mutation/summary.json",
    "test:mutation": "npm run test:mutation:run && npm run test:mutation:summary"
  },
  "dependencies": {
    "@multaiplayer/protocol": "0.1.0-alpha.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
