{
  "name": "@multaiplayer/relay",
  "private": true,
  "version": "0.1.0-alpha.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test:security-journey": "tsx --test --test-reporter=junit test/process-security-journey.test.ts test/live-native-relay-journey.test.ts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "deletions:reconcile": "node dist/reconcile-deletions.js",
    "restrictions:manage": "node dist/manage-account-restriction.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts test/auth/*.test.ts test/config/*.test.ts test/http/*.test.ts test/persistence/*.test.ts test/ws/*.test.ts",
    "test:fuzz": "MULTAIPLAYER_RELAY_FUZZ_ITERATIONS=${MULTAIPLAYER_RELAY_FUZZ_ITERATIONS:-100000} tsx --test test/fuzz/*.test.ts",
    "test:soak": "tsx --test test/soak/relay-chaos.test.ts",
    "test:coverage": "c8 --all --src src --include src/authz.ts --reporter=text --reporter=json-summary --reporter=lcov --check-coverage --lines=90 --functions=90 --branches=90 --statements=90 tsx --test test/security-units.test.ts",
    "test:mutation:run": "stryker run",
    "test:mutation:summary": "node ../../scripts/summarize-mutation-report.mjs reports/mutation/mutation.json --output reports/mutation/summary.json",
    "test:mutation:policy": "node ../../scripts/check-mutation-policy.mjs reports/mutation/summary.json mutation-policy.json",
    "test:mutation": "npm run test:mutation:run && npm run test:mutation:summary && npm run test:mutation:policy"
  },
  "dependencies": {
    "@multaiplayer/github": "0.1.0-alpha.0",
    "@multaiplayer/protocol": "0.1.0-alpha.0",
    "better-sqlite3": "12.11.1",
    "cookie": "2.0.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "express": "5.2.1",
    "nanoid": "6.0.0",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.20.1",
    "@types/ws": "8.18.1",
    "fast-check": "4.9.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  }
}
