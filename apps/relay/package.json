{
  "name": "@multaiplayer/relay",
  "private": true,
  "version": "0.1.0-alpha.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts test/*/*.test.ts",
    "test:coverage": "c8 --all --src src --include src/authz.ts --include src/limits.ts --reporter=text --reporter=json-summary --reporter=lcov --check-coverage --lines=90 --functions=90 --branches=85 --statements=90 tsx --test test/security-units.test.ts"
  },
  "dependencies": {
    "@multaiplayer/github": "0.1.0-alpha.0",
    "@multaiplayer/protocol": "0.1.0-alpha.0",
    "better-sqlite3": "^12.11.1",
    "cookie": "^2.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "nanoid": "^5.0.9",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.20.1",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
