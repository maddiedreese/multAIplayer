{
  "name": "@multaiplayer/desktop",
  "private": true,
  "version": "0.1.0-alpha.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build && node ../../scripts/verify-desktop-security-deps.mjs",
    "check": "tsc --noEmit",
    "test": "node ../../scripts/run-desktop-tests.mjs",
    "test:smoke": "node ../../scripts/run-desktop-tests.mjs --smoke-only",
    "preview": "vite preview",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:prebuilt": "tauri build --config src-tauri/tauri.prebuilt.conf.json",
    "tauri:build:native-e2e": "tauri build --debug --bundles app --features native-e2e --config src-tauri/tauri.native-e2e.conf.json"
  },
  "dependencies": {
    "@multaiplayer/git": "0.1.0-alpha.0",
    "@multaiplayer/github": "0.1.0-alpha.0",
    "@multaiplayer/protocol": "0.1.0-alpha.0",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@multaiplayer/codex": "0.1.0-alpha.0",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "monaco-editor": "0.55.1",
    "postcss": "8.5.17",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vite": "8.1.4"
  }
}
