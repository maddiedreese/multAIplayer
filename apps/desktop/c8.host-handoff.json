{
  "all": true,
  "src": ["src"],
  "include": [
    "src/application/handoff/hostHandoffActions.ts",
    "src/hooks/useHostHandoffActions.ts",
    "src/store/slices/codexHostHandoffSlice.ts"
  ],
  "check-coverage": true,
  "per-file": true,
  "lines": 75,
  "statements": 75,
  "functions": 50,
  "branches": 50,
  "temp-directory": "coverage/tmp",
  "report-dir": "coverage-host-handoff",
  "reporter": ["text", "json-summary", "lcov"]
}
