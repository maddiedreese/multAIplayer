{
  "all": true,
  "src": ["src"],
  "include": ["src/**/*.{ts,tsx}"],
  "exclude": ["src/**/*.d.ts"],
  "temp-directory": "coverage/tmp",
  "report-dir": "coverage",
  "reporter": ["text", "json-summary", "lcov"],
  "check-coverage": true,
  "lines": 50,
  "statements": 50,
  "functions": 60,
  "branches": 75
}
